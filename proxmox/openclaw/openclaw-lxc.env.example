# Copy this file to openclaw-lxc.env on the Proxmox node and adjust values.
# Do not commit the real env file; it is ignored by .gitignore.

# Proxmox container settings
CTID=240
HOSTNAME=openclaw
TEMPLATE_STORAGE=local
TEMPLATE=debian-12-standard_12.7-1_amd64.tar.zst
ROOTFS_STORAGE=local-lvm
ROOTFS_SIZE_GB=32
MEMORY_MB=4096
SWAP_MB=1024
CORES=2
BRIDGE=vmbr0
IP_CONFIG=dhcp
GATEWAY=
SSH_PUBLIC_KEY_FILE=

# OpenClaw settings
OPENCLAW_USER=openclaw
OPENCLAW_PREFIX=/home/openclaw/.openclaw
OPENCLAW_VERSION=latest
OPENCLAW_INSTALL_METHOD=npm
OPENCLAW_NO_ONBOARD=1

# Backup settings
PROXMOX_BACKUP_STORAGE=truenas-backups
PROXMOX_BACKUP_MODE=snapshot
PROXMOX_BACKUP_COMPRESS=zstd
PROXMOX_RUN_VZDUMP=0
OPENCLAW_BACKUP_HOST_DIR=/mnt/pve/truenas-openclaw
OPENCLAW_BACKUP_INCLUDE_WORKSPACE=0
