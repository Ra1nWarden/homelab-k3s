# Copy this file to k3s-worker.env on the Proxmox node and adjust values.
# Do not commit the real env file; it is ignored by .gitignore.

# Worker VM identity.
VMID=301
VM_NAME=k3s-worker-01
VM_FQDN=k3s-worker-01.home.arpa

# Base cloud-init VM template. This is a Proxmox VM template object, not a file
# in git. The create script builds it from the Ubuntu Server cloud image if it
# does not already exist.
TEMPLATE_VMID=9001
TEMPLATE_NAME=ubuntu-2404-cloud-k3s-template
REBUILD_TEMPLATE=0

# Official Ubuntu 24.04 LTS Server cloud image for KVM.
IMAGE_URL=https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img
IMAGE_FILE=noble-server-cloudimg-amd64.img
IMAGE_DOWNLOAD_DIR=/var/lib/vz/template/iso
# Optional sha256 for pinning a specific image. Leave empty to skip checksum validation.
IMAGE_SHA256=

# Proxmox VM resources.
STORAGE=local-lvm
SNIPPETS_STORAGE=local
# Leave empty to use /var/lib/vz/snippets for SNIPPETS_STORAGE=local.
SNIPPETS_DIR=
BRIDGE=vmbr0
CORES=2
MEMORY_MB=4096
DISK_SIZE_GB=40
CI_USER=ubuntu
ONBOOT=1
START_VM=1

# Networking. Use "dhcp" or a static Proxmox cloud-init value such as
# 192.168.1.231/24 plus GATEWAY=192.168.1.1.
IP_CONFIG=dhcp
GATEWAY=
NAMESERVER=
SEARCHDOMAIN=

# SSH access for the cloud image user.
SSH_PUBLIC_KEY_FILE=

# Existing k3s cluster join settings. Keep K3S_TOKEN out of plaintext git.
K3S_URL=https://192.168.1.223:6443
K3S_TOKEN=
# Extra arguments passed to k3s agent, for example:
# K3S_EXTRA_ARGS=--node-label storage=local-ssd
K3S_EXTRA_ARGS=
INSTALL_K3S=1

# Local storage compatibility. The existing local-ssd StorageClass expects
# /mnt/ssd on every node. If LOCAL_SSD_SIZE_GB is greater than 0, the script
# attaches a second virtual disk and cloud-init formats/mounts it at /mnt/ssd.
PREPARE_LOCAL_SSD=1
LOCAL_SSD_SIZE_GB=40
LOCAL_SSD_DEVICE=/dev/sdb
